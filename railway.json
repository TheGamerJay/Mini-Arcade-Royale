{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "railpack",
    "watchPaths": [
      "backend/**",
      "frontend/**",
      "requirements.txt",
      "Dockerfile"
    ]
  },
  "deploy": {
    "startCommand": "sh -c /app/start.sh",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckInterval": 10,
    "healthcheckTimeout": 5,
    "startTimeout": 60
  },
  "variables": {
    "APP_ENV": "production",
    "PORT": "8080",
    "LOG_LEVEL": "info",
    "NODE_ENV": "production",
    "DATABASE_URL": "${{ RAILWAY_DATABASE_URL }}"
  }
}
