# Mini Arcade Royale — Environment Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)
# For production, use secure secret management (AWS Secrets Manager, Vault, etc.)

# ============================================================================
# APP CONFIGURATION
# ============================================================================

# Application name (shown in UI, emails, etc.)
APP_NAME=Mini Arcade Royale

# Environment: development | staging | production
APP_ENV=development

# App URLs (used in links, redirects, CORS)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# IMPORTANT: Use strong password in production
DATABASE_URL=postgresql://arcade_dev:arcade_pass@localhost:5432/arcade_royale_dev

# Database connection pooling (optional, for production)
DATABASE_POOL_SIZE=20
DATABASE_POOL_PRE_PING=true

# ============================================================================
# CACHE & LOCKS (Optional, can skip for basic dev)
# ============================================================================

# Redis URL (used for rate limits, locks, caching)
# Format: redis://[:password@]host[:port]/[database]
# If not set, will use in-memory cache (not suitable for production)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Session security
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=your-random-session-secret-at-least-32-chars

# JWT token signing (if using JWT auth)
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# CSRF protection
CSRF_SECRET=your-random-csrf-secret-at-least-32-chars

# Cookie configuration
SECURE_COOKIES=false              # Set to true in production (requires HTTPS)
COOKIE_DOMAIN=localhost           # Set to .mini-arcade-royale.com in production
COOKIE_SAME_SITE=lax              # strict | lax | none

# ============================================================================
# STRIPE PAYMENTS
# ============================================================================

# Stripe API keys (KEEP SECRET!)
# Test keys format: sk_test_... / pk_test_...
# Live keys format: sk_live_... / pk_live_...
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/webhooks
# Format: whsec_test_... or whsec_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Price IDs (from Stripe Dashboard -> Products)
# Example: price_1abc123XYZ...
# Leave empty to look up dynamically, or hardcode for performance
STRIPE_PRICE_IDS=price_1Abc123Xyz|price_1Def456Uvw

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Email provider: resend | sendgrid | aws-ses | smtp
EMAIL_PROVIDER=resend

# Resend.com API key (https://resend.com)
# Format: re_live_... or re_...
RESEND_API_KEY=re_...

# SendGrid API key (https://sendgrid.com) — alternative to Resend
SENDGRID_API_KEY=SG.abc123...

# AWS SES (if using AWS) — alternative
AWS_SES_REGION=us-east-1

# Email sender details
EMAIL_FROM=noreply@mini-arcade-royale.local
EMAIL_FROM_NAME=Mini Arcade Royale

# Support emails
SUPPORT_EMAIL=support@mini-arcade-royale.local
ADMIN_EMAIL=admin@mini-arcade-royale.local

# Email templates (optional override)
# Leave empty to use defaults in /templates/email/
EMAIL_TEMPLATE_DIR=templates/email

# ============================================================================
# OBSERVABILITY & MONITORING
# ============================================================================

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG          # Use INFO in production

# Log format: json | text
LOG_FORMAT=text          # Use json in production for better parsing

# Sentry (error tracking) — https://sentry.io
# Leave empty to disable
SENTRY_DSN=https://key@sentry.io/project-id

# Sentry environment
SENTRY_ENVIRONMENT=development

# Sentry sample rate (0.0 to 1.0)
# Use 0.1 (10%) in production to reduce quota
SENTRY_SAMPLE_RATE=1.0

# DataDog (full observability) — https://www.datadoghq.com
# Leave empty to disable
DD_API_KEY=
DD_SERVICE=arcade-royale
DD_ENV=development

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit configuration (JSON)
# Keys: auth_signup | auth_login | auth_forgot_password | game_play
# Values: requests per period (e.g., 5 requests per hour)
RATE_LIMIT_CONFIG={"auth_signup":5,"auth_login":10,"game_play":100}

# Rate limit storage: memory | redis
# Use 'redis' only if REDIS_URL is set
RATE_LIMIT_STORAGE=memory

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Feature flags (JSON format)
# Example: {"membership":true,"seasonal_events":false}
# Use FEATURE_FLAGS to control rollouts safely
FEATURE_FLAGS={"membership":false,"achievements":true,"leaderboard":true}

# ============================================================================
# ADMIN & OPERATIONS
# ============================================================================

# Admin bootstrap (initial setup)
# Set to true to create default admin user on first run
ADMIN_BOOTSTRAP=true

# Admin panel access password (if using simple auth)
ADMIN_PASSWORD_HASH=

# Timezone (for timestamps, reports)
TIMEZONE=UTC

# CORS allowed origins (comma-separated)
# Production: separate by domain, use specific domains
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# LEGAL & COMPLIANCE
# ============================================================================

# Legal acceptance policy version
# Increment when legal pages change to require user re-acceptance
LEGAL_POLICY_VERSION=1

# Age requirement (in years)
MIN_USER_AGE=18

# Enable GDPR data deletion after inactivity (days)
# Leave empty to disable
GDPR_DELETE_AFTER_DAYS=

# ============================================================================
# GAME CONFIGURATION
# ============================================================================

# Default game costs (in credits)
GAME_COST_SCRATCH_ROYALE=10
GAME_COST_ROYALE_SPIN=15
GAME_COST_MYSTERY_VAULT=20

# Enable/disable games
GAME_ENABLED_SCRATCH_ROYALE=true
GAME_ENABLED_ROYALE_SPIN=true
GAME_ENABLED_MYSTERY_VAULT=true

# ============================================================================
# STORE & PACKAGES
# ============================================================================

# First purchase bonus (percentage multiplier, e.g., 1.2 = 20% bonus)
FIRST_PURCHASE_BONUS_MULTIPLIER=1.2

# Promo code settings
PROMO_CODE_ENABLED=true
PROMO_CODE_MAX_USES_GLOBAL=1000
PROMO_CODE_MAX_USES_PER_USER=1

# ============================================================================
# SESSION & PERSISTENCE
# ============================================================================

# Session timeout (minutes)
SESSION_TIMEOUT_MINUTES=1440  # 24 hours

# Session storage: cookie | redis
# Use 'redis' for distributed systems / multiple servers
SESSION_STORAGE=cookie

# Password reset token expiry (hours)
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# Email verification token expiry (days)
EMAIL_VERIFICATION_TOKEN_EXPIRY_DAYS=7

# ============================================================================
# SECURITY HEADERS & POLICY
# ============================================================================

# Content Security Policy (CSP)
# Strict CSP in production
CSP_ENABLED=true
CSP_REPORT_ONLY=false  # Set to true to test before enforcement

# CORS settings
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Debug mode (set to false in production!)
DEBUG=true

# Allow SQL query logging
SQL_ECHO=false          # Set to true to see all queries in logs

# Stripe webhook forwarding (for local development with Stripe CLI)
STRIPE_WEBHOOK_ENDPOINT_ID=we_1abc123...

# ============================================================================
# DEPLOYMENT & INFRASTRUCTURE
# ============================================================================

# Server bind address and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Worker count (uvicorn / gunicorn)
WORKERS=4                # Set to number of CPU cores

# Access log format
ACCESS_LOG_FORMAT=default

# ============================================================================
# OPTIONAL: Third-Party Integrations
# ============================================================================

# Google Analytics (frontend)
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Mixpanel (analytics)
MIXPANEL_TOKEN=

# Amplitude (behavioral analytics)
AMPLITUDE_API_KEY=

# Hotjar (session recordings, optional)
HOTJAR_ID=

# ============================================================================
# NOTES
# ============================================================================

# 1. NEVER commit this file with real secrets to git
# 2. Use .env.local for local development (git-ignored)
# 3. For production:
#    - Use AWS Secrets Manager / HashiCorp Vault
#    - Rotate secrets regularly
#    - Enable audit logging on secret access
#    - Use strong, random values for all secrets
#        python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 4. For staging/testing:
#    - Keep SECURE_COOKIES=false (until domain set up)
#    - Use Stripe test keys (sk_test_..., pk_test_...)
#    - Use test email addresses
#
# 5. The following MUST be set before launch:
#    - STRIPE_SECRET_KEY (live key)
#    - STRIPE_WEBHOOK_SECRET (live key)
#    - EMAIL_FROM (real domain)
#    - SENTRY_DSN (if using error tracking)
#    - SECURE_COOKIES=true
#    - DEBUG=false
#
# 6. Secrets rotation schedule:
#    - SESSION_SECRET: Monthly
#    - JWT_SECRET: Monthly
#    - STRIPE keys: Never (rotate via Stripe dashboard)
#    - Email API keys: Every 90 days
#
# ============================================================================
